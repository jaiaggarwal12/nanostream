# ──────────────────────────────────────────────────────────
# NanoStream Environment Variables
# Copy this file to .env and fill in your values.
# On Render, set these in the dashboard or render.yaml.
# ──────────────────────────────────────────────────────────

# Redis connection (auto-set by Render when using the Redis service)
# For local dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Backblaze B2 (optional — free video storage, NO card required) ──
# Sign up free: https://www.backblaze.com/sign-up/cloud-storage
# Leave blank to store HLS files locally only (lost on Render restart).

# From: Account → App Keys → Add New Application Key
B2_KEY_ID=
B2_APPLICATION_KEY=

# Bucket name you created (set to Public)
B2_BUCKET=nanostream

# From: Bucket page → Endpoint  e.g. s3.us-west-004.backblazeb2.com
B2_ENDPOINT=

# Public URL for streaming: https://f004.backblazeb2.com/file/nanostream
# The "f004" part matches the number in your endpoint (us-west-004 → f004)
B2_PUBLIC_URL=

# ── App settings ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
