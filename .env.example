# ──────────────────────────────────────────────────────────
# NanoStream Environment Variables
# Copy this file to .env and fill in your values.
# On Render, set these in the dashboard or render.yaml.
# ──────────────────────────────────────────────────────────

# Redis connection (auto-set by Render when using the Redis service)
# For local dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Cloudflare R2 (optional — for cloud HLS storage/CDN) ──
# Get these from: Cloudflare dashboard → R2 → Manage API Tokens
# Leave blank to store HLS files locally only.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nanostream
# Get this from: R2 bucket → Settings → Public Access
R2_PUBLIC_URL=

# ── App settings ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
