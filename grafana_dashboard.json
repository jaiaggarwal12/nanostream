{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "NanoStream - Video Delivery Platform",
  "uid": "nanostream-main",
  "version": 1,
  "schemaVersion": 37,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Completed (total)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "sum(nanostream_jobs_total{status='completed'})",
        "legendFormat": "Completed"
      }],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "nanostream_queue_depth{status='queued'} + nanostream_queue_depth{status='processing'}",
        "legendFormat": "Pending"
      }],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "title": "Active Viewers",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "nanostream_active_viewers",
        "legendFormat": "Viewers"
      }],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4,
      "title": "Bandwidth Served (GB)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "sum(nanostream_bandwidth_served_gb_total)",
        "legendFormat": "GB Served"
      }],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 5,
      "title": "Encoding Jobs Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(nanostream_jobs_total{status='completed'}[5m])",
          "legendFormat": "{{codec}} completed"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(nanostream_jobs_total{status='failed'}[5m])",
          "legendFormat": "{{codec}} failed"
        }
      ]
    },
    {
      "id": 6,
      "title": "Queue Depth Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "nanostream_queue_depth{status='queued'}",
          "legendFormat": "Queued"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "nanostream_queue_depth{status='processing'}",
          "legendFormat": "Processing"
        }
      ]
    },
    {
      "id": 7,
      "title": "Encoding Duration (p50 / p95) by Codec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.50, rate(nanostream_encode_duration_seconds_bucket[10m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(nanostream_encode_duration_seconds_bucket[10m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "title": "Compression Ratio by Codec",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "nanostream_compression_ratio",
        "legendFormat": "{{codec}}"
      }],
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 9,
      "title": "PSNR Quality (dB) by Codec",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "nanostream_psnr_db",
        "legendFormat": "{{codec}}"
      }],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 30},
            {"color": "green", "value": 35}
          ]
        }
      }
    },
    {
      "id": 10,
      "title": "HTTP Request Latency (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "histogram_quantile(0.95, rate(nanostream_http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "{{endpoint}}"
      }]
    }
  ]
}
